# =====================================================================
# Shibei On-Chain Agent — example environment
# Copy to `.env` and fill in. SAFE DEFAULTS = dry-run, testnet, no keys.
# The agent will NOT submit a real swap until EVERY live gate is satisfied
# (see "LIVE GATE" below). Keep your private key OUT of git (.gitignore covers .env).
# =====================================================================

# --------------------------- LIVE GATE -------------------------------
# All of these must be set for live_orders_allowed to become true.
SHIBEI_ONCHAIN_DRY_RUN=true                       # true => simulate only, never sign
SHIBEI_ONCHAIN_TRADING_ENABLED=false              # master on/off switch
SHIBEI_ONCHAIN_EXECUTION_ADAPTER_READY=false      # arm the on-chain adapter
SHIBEI_ONCHAIN_CONFIRM_TEXT=                       # must equal I_UNDERSTAND_SHIBEI_ONCHAIN_LIVE_RISK
# wallet_address + private_key (below) must also be present.

# --------------------------- GENERAL ---------------------------------
SHIBEI_ONCHAIN_STATE_DIR=data/state
SHIBEI_ONCHAIN_INITIAL_EQUITY_USD=1000
SHIBEI_ONCHAIN_MAX_CANDIDATES=8
SHIBEI_ONCHAIN_ENABLE_SHORT_LEG=                  # default: on when venue=aster

# ------------------- EXECUTION VENUE --------------------------------
# pancake = long-only spot swaps on PancakeSwap.
# aster   = BOTH legs as Aster perps (long perp / short perp); auto-enables short.
SHIBEI_ONCHAIN_VENUE=aster
SHIBEI_ONCHAIN_ASTER_MODE=mock                    # mock | api (real signed /fapi/v3/*)
SHIBEI_ONCHAIN_ASTER_BASE_URL=https://fapi.asterdex-testnet.com   # prod: https://fapi.asterdex.com
SHIBEI_ONCHAIN_ASTER_DEFAULT_LEVERAGE=3
SHIBEI_ONCHAIN_ASTER_MARGIN_ASSET=USDT
# v3 EIP-712 auth: a registered agent/signer wallet signs each request.
# Create it at the Aster api-wallet page; defaults to your main wallet/key if unset.
SHIBEI_ONCHAIN_ASTER_SIGNER_ADDRESS=
SHIBEI_ONCHAIN_ASTER_SIGNER_PRIVATE_KEY=

# --------------------- RISK STACK (拾贝 V3.0) ------------------------
SHIBEI_ONCHAIN_LONG_RISK_PCT=0.02                 # 2% risk per long trade
SHIBEI_ONCHAIN_SHORT_RISK_PCT=0.02                # 2% risk per short trade
SHIBEI_ONCHAIN_TAKE_PROFIT_R=2.5
SHIBEI_ONCHAIN_LONG_BREAKEVEN_R=1.0
SHIBEI_ONCHAIN_MAX_STOP_DISTANCE_PCT=0.20
SHIBEI_ONCHAIN_MAX_TOTAL_NOTIONAL_MULTIPLE=5.0    # <=5x equity in open notional
SHIBEI_ONCHAIN_MAX_TOTAL_INITIAL_RISK_PCT=0.12    # <=12% total initial risk
SHIBEI_ONCHAIN_MAX_NEW_ORDERS_PER_HOUR=3          # <=3 new orders / hour
SHIBEI_ONCHAIN_MAX_LEVERAGE=5
SHIBEI_ONCHAIN_MIN_NOTIONAL_USDT=10
SHIBEI_ONCHAIN_FEE_RATE=0.0005
SHIBEI_ONCHAIN_CIRCUIT_BREAKER_STOPLOSS_COUNT=2   # 2 stop-losses on same coin in window => block
SHIBEI_ONCHAIN_CIRCUIT_BREAKER_WINDOW_HOURS=24
SHIBEI_ONCHAIN_S16A_V0_MAX_HOLD_HOURS=16
SHIBEI_ONCHAIN_S16A_V1_MAX_HOLD_HOURS=24
SHIBEI_ONCHAIN_BTC_GATE_ENABLED=true              # enforce BTC environment gate (V3.0 gap-fill)

# ------------------- SIGNAL · CoinMarketCap Agent Hub ----------------
SHIBEI_ONCHAIN_CMC_MODE=mock                      # mock | mcp | x402
SHIBEI_ONCHAIN_CMC_MCP_URL=https://mcp.coinmarketcap.com/mcp
SHIBEI_ONCHAIN_CMC_X402_URL=https://mcp.coinmarketcap.com/x402/mcp
SHIBEI_ONCHAIN_CMC_API_KEY=                        # required only for mode=mcp
SHIBEI_ONCHAIN_CMC_TIMEOUT_SECONDS=15

# --------- EXECUTION · Trust Wallet Agent Kit @ BNB Chain ------------
SHIBEI_ONCHAIN_CHAIN=bsc-testnet
SHIBEI_ONCHAIN_CHAIN_ID=97
SHIBEI_ONCHAIN_RPC_URL=https://data-seed-prebsc-1-s1.bnbchain.org:8545/
SHIBEI_ONCHAIN_PANCAKE_ROUTER=0xD99D1c33F9fC3444f8101754aBC46c52416550D1
SHIBEI_ONCHAIN_WBNB_ADDRESS=0xae13d989daC2f0dEbFf460aC112a837C89BAa7cd
SHIBEI_ONCHAIN_USDT_ADDRESS=0x337610d27c682E347C9cD60BD4b3b107C9d34dDd
SHIBEI_ONCHAIN_TOKENS_PATH=config/tokens.bsc.json
SHIBEI_ONCHAIN_MAX_SLIPPAGE_BPS=100               # 1.00% max slippage
SHIBEI_ONCHAIN_GAS_MIN_BNB=0.01                   # refuse to trade below this gas floor
SHIBEI_ONCHAIN_APPROVE_EXACT=true                 # exact-amount approvals, no infinite allowance
SHIBEI_ONCHAIN_TWAK_MODE=mock                     # mock | web3 | mcp | cli
SHIBEI_ONCHAIN_TWAK_ENDPOINT=                      # MCP url or CLI binary path
SHIBEI_ONCHAIN_EXPLORER_BASE=https://testnet.bscscan.com

# secrets — self-custody, NEVER leaves your machine
SHIBEI_ONCHAIN_WALLET_ADDRESS=
SHIBEI_ONCHAIN_PRIVATE_KEY=

# --------------------------- DELIVERY · Feishu -----------------------
SHIBEI_ONCHAIN_FEISHU_ENABLED=false
SHIBEI_ONCHAIN_FEISHU_WEBHOOK_URL=
SHIBEI_ONCHAIN_FEISHU_WEBHOOK_SECRET=
